@* Transport (HTTP / WebSocket) buttons + SSL switch, shared by the add/edit connection form and the
   active connection card. Mutates the passed connection object directly (it's a reference), so no
   change callback is needed — the caller reads the values back off the same object. *@
@using GraphDBViewerWeb.Code

<div class="mb-2">
    <label class="form-label d-block">Transport <span class="text-muted fw-normal" style="font-size: 0.65em;">(Apache TinkerPop uses websockets by default)</span></label>
    <div class="d-flex align-items-center gap-3">
        <div class="btn-group" role="group" aria-label="Transport protocol">
            <button type="button"
                    class="btn @(Connection.Transport == "HTTP" ? "btn-primary" : "btn-outline-primary")"
                    disabled="@Disabled"
                    @onclick='() => Connection.Transport = "HTTP"'>
                HTTP
            </button>
            <button type="button"
                    class="btn @(Connection.Transport == "WebSocket" ? "btn-primary" : "btn-outline-primary")"
                    disabled="@Disabled"
                    @onclick='() => Connection.Transport = "WebSocket"'>
                WebSocket
            </button>
        </div>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="@sslToggleId" @bind="Connection.UseSSL" disabled="@Disabled" />
            <label class="form-check-label" for="@sslToggleId">
                SSL
                <span class="badge @(Connection.UseSSL ? "bg-success" : "bg-secondary") ms-1" style="font-size: 0.7em;">
                    @(Connection.UseSSL
                        ? (Connection.Transport == "WebSocket" ? "wss" : "https")
                        : (Connection.Transport == "WebSocket" ? "ws" : "http"))
                </span>
            </label>
        </div>
        <div class="text-warning-emphasis" style="font-size: 0.75em; flex: 1 1 0; min-width: 0;">
            <div>⚠ If your database doesn't have a secure connection, be sure to toggle off SSL or the connection is going to fail.</div>
            <div class="mt-1">⚠ You may also need to enable CORS on the database (or put a proxy in front of it), or the connection might fail.</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public GremlinDB.GremlinConnection Connection { get; set; }
    [Parameter] public bool Disabled { get; set; }

    //Unique per instance so the checkbox/label pairing works when both the form and the active card render at once.
    private readonly string sslToggleId = "ssl-" + Guid.NewGuid().ToString("N");
}
