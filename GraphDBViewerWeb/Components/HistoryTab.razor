<div class="border rounded p-2" style="height: 15em; overflow-y: auto;">
    @if (History.Count == 0)
    {
        <div class="text-muted" style="font-size: 0.8em;">No queries run yet. Queries you run from the Query tab appear here.</div>
    }
    else
    {
        <div class="text-muted mb-2" style="font-size: 0.75em;">Last @History.Count run quer@(History.Count == 1 ? "y" : "ies") — click to load into the Query tab.</div>
        <div class="list-group list-group-flush">
            @foreach (var q in History)
            {
                var query = q;
                <button type="button" class="list-group-item list-group-item-action py-1 px-2 text-truncate" style="font-size: 0.78em; font-family: monospace;" title="@query" @onclick="() => OnSelect.InvokeAsync(query)">
                    @query
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<string> History { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<string> OnSelect { get; set; }
}
