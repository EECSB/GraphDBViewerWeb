@using System.Text.Json
@using GraphDBViewerWeb.Code

@if (Data.ValueKind != JsonValueKind.Undefined)
{
    var table = GraphDataConverter.ToTable(Data);

    @if (table.Nodes.Count > 0 || table.Edges.Count > 0)
    {
        <details class="mt-2 flex-shrink-0">
            <summary class="text-muted" style="font-size: 0.85em; cursor: pointer;">
                <span class="fw-bold">@table.Nodes.Count</span> vertices · <span class="fw-bold">@table.Edges.Count</span> edges
                @if (QueryMs.HasValue)
                {
                    <text> · <span class="fw-bold" title="Time to run the last query">@FormatMs(QueryMs.Value)</span> query</text>
                }
            </summary>

            <div class="d-flex flex-wrap gap-4 mt-2" style="font-size: 0.8em;">
                @if (table.Nodes.Count > 0)
                {
                    <div>
                        <div class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.7em;">Vertex labels</div>
                        @foreach (var grp in table.Nodes.GroupBy(n => n.Label).OrderByDescending(g => g.Count()))
                        {
                            <span class="badge bg-secondary me-1 mb-1">@grp.Key: @grp.Count()</span>
                        }
                    </div>
                }
                @if (table.Edges.Count > 0)
                {
                    <div>
                        <div class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.7em;">Edge labels</div>
                        @foreach (var grp in table.Edges.GroupBy(e => e.Label).OrderByDescending(g => g.Count()))
                        {
                            <span class="badge bg-secondary me-1 mb-1">@grp.Key: @grp.Count()</span>
                        }
                    </div>
                }
            </div>
        </details>
    }
}

@code {
    [Parameter] public JsonElement GraphData { get; set; }
    [Parameter] public JsonElement FallbackData { get; set; }
    [Parameter] public double? QueryMs { get; set; }

    //Formats an elapsed query time: whole milliseconds, switching to seconds past 1000 ms.
    private static string FormatMs(double ms)
    {
        if (ms >= 1000)
            return $"{ms / 1000:0.##} s";
        else
            return $"{ms:0} ms";
    }

    private JsonElement Data
    {
        get
        {
            if (GraphData.ValueKind != JsonValueKind.Undefined)
                return GraphData;
            else
                return FallbackData;
        }
    }
}
