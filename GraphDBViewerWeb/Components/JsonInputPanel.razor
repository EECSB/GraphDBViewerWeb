@using System.Text.Json
@using GraphDBViewerWeb.Code

<div class="mt-2" style="max-width: 480px;">

    <label class="form-label d-block mb-1">
        Visualize pasted graph
        <span class="text-muted fw-normal" style="font-size: 0.65em;">(offline — no connection needed)</span>
    </label>

    <div class="form-text mt-0 mb-2" style="font-size: 0.75em;">
        Paste GraphSON (from <span class="fw-semibold"><span class="btn-ico ico-copy"></span>Copy graph</span>), <span class="fw-semibold">Graphviz DOT</span> / <span class="fw-semibold">Mermaid</span>, or <span class="fw-semibold">exported addV/addE queries</span> to redraw them. DOT/Mermaid also generate queries in the box.
    </div>

    <textarea class="form-control" style="resize:vertical; height: 6em; max-width: 480px; font-family: monospace; font-size: 0.8em;" placeholder="GraphSON array, or DOT / Mermaid, e.g. digraph { a -&gt; b [label=knows] }" @bind="json" @bind:event="oninput"></textarea>

    <div class="d-flex gap-2 mt-2 align-items-center">
        <button class="btn btn-primary btn-sm" @onclick="Visualize" disabled="@string.IsNullOrWhiteSpace(json)">Visualize</button>
        <button class="btn btn-sm @(string.IsNullOrWhiteSpace(json) ? "btn-dark" : "btn-primary")" @onclick="Generate" disabled="@string.IsNullOrWhiteSpace(json)" title="Convert to addV/addE in the query editor for importing into the database">Generate queries</button>
        <button class="btn btn-outline-secondary btn-sm text-body-emphasis" @onclick="Clear" disabled="@string.IsNullOrWhiteSpace(json)">Clear</button>

        @if (!string.IsNullOrEmpty(error))
        {
            <span class="text-danger" style="font-size: 0.85em;">@error</span>
        }

        <button class="btn btn-outline-primary btn-sm ms-auto" @onclick="LoadExample" title="Fill the box with a sample graph you can visualize offline">Example</button>
    </div>

</div>

@code {
    [Parameter] public EventCallback<string> OnVisualize { get; set; }
    [Parameter] public EventCallback<string> OnGenerate { get; set; }

    private string json;
    private string error;

    private async Task Visualize()
    {
        error = null;

        var trimmed = json?.Trim();
        if (string.IsNullOrEmpty(trimmed))
            return;

        if (!GraphImport.LooksLikeGraphText(trimmed) && !GraphImport.LooksLikeGremlin(trimmed) && !IsValidJson(trimmed))
        {
            error = "Paste GraphSON/JSON, Graphviz DOT, Mermaid, or exported addV/addE Gremlin.";
            return;
        }

        await OnVisualize.InvokeAsync(json);
    }

    private async Task Generate()
    {
        error = null;

        var trimmed = json?.Trim();
        if (string.IsNullOrEmpty(trimmed))
            return;

        if (!GraphImport.LooksLikeGraphText(trimmed) && !GraphImport.LooksLikeGremlin(trimmed) && !IsValidJson(trimmed))
        {
            error = "Paste GraphSON/JSON, Graphviz DOT, Mermaid, or exported addV/addE Gremlin.";
            return;
        }

        await OnGenerate.InvokeAsync(json);
    }

    private static bool IsValidJson(string text)
    {
        try
        {
            using var _ = JsonDocument.Parse(text);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private void Clear()
    {
        json = null;
        error = null;
    }

    private void LoadExample()
    {
        json = ExampleGraph;
        error = null;
    }

    //A small self-contained DOT graph so users can try the viewer offline (no DB connection needed).
    private const string ExampleGraph =
@"digraph {
    Alice -> Bob [label=knows]
    Bob -> Carol [label=knows]
    Carol -> Alice [label=knows]
    Alice -> Acme [label=worksAt]
    Bob -> Acme [label=worksAt]
    Carol -> Globex [label=worksAt]
    Acme -> Widget [label=makes]
    Globex -> Gadget [label=makes]
    Widget -> Steel [label=madeOf]
    Gadget -> Steel [label=madeOf]
}";
}
