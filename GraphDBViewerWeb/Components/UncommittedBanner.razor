@* Full-width bar over the graph canvas warning that staged (uncommitted) edits are being previewed.
   Home renders it only while previewing; Discard clears the staged queries and reverts the canvas. *@
<div class="alert alert-warning mb-0 d-flex align-items-center justify-content-center gap-2 py-1 px-3 position-absolute top-0 start-0 end-0"
     style="z-index: 1040; font-size: 0.8rem; border-radius: 0; border-top: 0; border-left: 0; border-right: 0;">
    <span style="font-size: 1rem;">⚠</span>
    <span>Showing <strong>uncommitted</strong> changes — not saved to the database yet. Review the Generated tab and <strong>Commit</strong> to apply.</span>
    <button class="btn btn-outline-danger btn-sm py-0 px-2 ms-2 text-nowrap" style="font-size: 0.75rem;" @onclick="OnDiscard" title="Discard the staged changes and return the canvas to the database state">Discard changes</button>
</div>

@code {
    [Parameter] public EventCallback OnDiscard { get; set; }
}
