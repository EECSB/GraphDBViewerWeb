@using GraphDBViewerWeb.Code
@inject HttpClient Http

@* Self-contained "Ask in English" popup: turns a plain-English request into a query (via ILlmProvider),
   which the caller drops into the editor. The saved AI-model connections live in LlmConnectionPicker /
   LlmConnectionStore, shared with the other AI features. Kept decoupled from the page layout so it can
   be relocated later. *@

@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onmousedown="() => backdropMouseDown = true" @onclick="CloseIfBackdropAsync">
        <div class="modal-dialog modal-xl" style="margin-top: 6rem;" @onmousedown="() => backdropMouseDown = false" @onmousedown:stopPropagation="true" @onclick:stopPropagation="true">
            <div class="modal-content" style="min-height: 60vh;">

                <div class="modal-header">
                    <h5 class="modal-title">✨ Ask in English</h5>
                    <button type="button" class="btn-close" @onclick="OnClose"></button>
                </div>

                <div class="modal-body d-flex flex-column">

                    @* ── AI model connection (shared picker + add/edit form) ─── *@
                    <LlmConnectionPicker SelectedChanged="c => selected = c" />

                    @* ── Natural-language request ────────────────────────────── *@
                    <label class="form-label mb-1">Describe what you want, in plain English</label>
                    <textarea class="form-control mb-1" style="height: 8em; resize: none;" placeholder="e.g. find all products made of metal and the components that compose them" @bind="nlPrompt" @bind:event="oninput"></textarea>

                    <br />

                    <div class="d-flex gap-2 align-items-center mb-2">
                        <button class="btn btn-primary" @onclick="GenerateAsync" disabled="@(selected == null || string.IsNullOrWhiteSpace(nlPrompt) || generating)">
                            @(generating ? "Generating…" : "Generate query")
                        </button>
                        @if (generating)
                        {
                            <button class="btn btn-outline-secondary" @onclick="Cancel" title="Cancel generation">Cancel</button>
                        }
                        <div class="form-text flex-grow-1 my-0">Generates a <strong>@NlQueryPrompt.LanguageDisplayName(Language)</strong> query, grounded in the connected graph's schema. Your request and the schema are sent to the selected model provider.</div>
                    </div>

                    @if (error != null)
                    {
                        <div class="alert alert-danger py-2 small mb-2">@error</div>
                    }

                    @if (generatedQuery != null)
                    {
                        <label class="form-label mb-1 mt-3">Generated query</label>
                        <pre class="border rounded p-2 mb-1" style="white-space: pre-wrap; flex: 1 1 auto; min-height: 6em; max-height: 45vh; overflow: auto;">@generatedQuery</pre>
                        @if (GeneratedIsMutating)
                        {
                            <div class="alert alert-warning py-2 small mb-0">⚠ This query modifies the graph. Review it carefully before running.</div>
                        }
                    }

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success" @onclick="UseGeneratedAsync" disabled="@(string.IsNullOrEmpty(generatedQuery))">Use this query →</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public SchemaVocabulary Schema { get; set; }
    [Parameter] public string Language { get; set; } = "gremlin";
    [Parameter] public EventCallback<string> OnUseQuery { get; set; }

    ///<summary>Optional tool runner (e.g. run read-only queries against the live DB) for providers that support tool use.</summary>
    [Parameter] public ILlmToolRunner ToolRunner { get; set; }

    //The connection the picker currently has selected; null when no models exist yet.
    private LlmConnection selected;

    //Generation state.
    private string nlPrompt;
    private bool generating;
    private CancellationTokenSource cts;
    private string generatedQuery;
    private string error;

    //Tracks where the mouse was pressed so a selection drag from inside the dialog to the backdrop
    //doesn't close the modal — only a press that begins on the backdrop does.
    private bool backdropMouseDown;

    private async Task CloseIfBackdropAsync()
    {
        if (backdropMouseDown)
            await OnClose.InvokeAsync();
    }

    private bool GeneratedIsMutating
    {
        get
        {
            if (Language != "gremlin" || string.IsNullOrEmpty(generatedQuery))
                return false;

            return GremlinStepParser.IsMutating(generatedQuery);
        }
    }

    private async Task GenerateAsync()
    {
        if (selected == null || string.IsNullOrWhiteSpace(nlPrompt))
            return;

        error = null;
        generatedQuery = null;
        generating = true;
        cts?.Dispose();
        cts = new CancellationTokenSource();

        try
        {
            var provider = LlmProviderFactory.Create(Http, selected);
            var useTools = ToolRunner != null && Language == "gremlin" && provider is IToolUsingLlmProvider;
            var system = NlQueryPrompt.BuildSystemPrompt(Language, Schema, useTools);

            LlmResult result;

            if (useTools)
                result = await ((IToolUsingLlmProvider)provider).CompleteWithToolsAsync(system, nlPrompt.Trim(), ToolRunner, cts.Token);
            else
                result = await provider.CompleteAsync(system, nlPrompt.Trim(), cts.Token);

            if (result.IsError)
                error = result.Error;
            else
                generatedQuery = NlQueryPrompt.CleanQuery(result.Text);
        }
        catch (OperationCanceledException)
        {
            error = "Generation canceled.";
        }
        catch (Exception ex)
        {
            //A CORS preflight rejection surfaces as a bare fetch failure — the likeliest real error for
            //a custom/local endpoint. Name the cause, with the connection card's wording.
            error = ex.Message;

            if (ex is HttpRequestException || error.Contains("Failed to fetch"))
                error += " (If this is a CORS error, the endpoint must allow this origin.)";
        }
        finally
        {
            generating = false;
            cts?.Dispose();
            cts = null;
        }
    }

    private void Cancel()
    {
        cts?.Cancel();
    }

    private async Task UseGeneratedAsync()
    {
        if (string.IsNullOrEmpty(generatedQuery))
            return;

        await OnUseQuery.InvokeAsync(generatedQuery);
        await OnClose.InvokeAsync();
    }
}
