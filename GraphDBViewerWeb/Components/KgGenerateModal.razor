@using System.Text.Json
@using GraphDBViewerWeb.Code
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IAppStorage Storage

@* "✨ Generate with AI": turns pasted text into a knowledge graph via the shared AI models, previews the
   result — counts, label breakdown, every repair warning, and the exact Gremlin — and hands the caller
   the script plus the chosen Merge/Replace mode. It never renders, stages or commits anything itself
   (AC 10): the caller owns what "use" means. Mirrors NlQueryModal's shell and backdrop pattern. *@

@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onmousedown="() => backdropMouseDown = true" @onclick="CloseIfBackdropAsync">
        <div class="modal-dialog modal-xl" style="margin-top: 4rem;" @onmousedown="() => backdropMouseDown = false" @onmousedown:stopPropagation="true" @onclick:stopPropagation="true">
            <div class="modal-content" style="min-height: 60vh;">

                <div class="modal-header">
                    <h5 class="modal-title">✨ Generate a graph from text</h5>
                    <button type="button" class="btn-close" @onclick="OnClose"></button>
                </div>

                <div class="modal-body d-flex flex-column">

                    @* ── AI model connection (shared picker + add/edit form) ─── *@
                    <LlmConnectionPicker SelectedChanged="c => selected = c" />

                    @* ── Source text ─────────────────────────────────────────── *@
                    <div class="d-flex align-items-center gap-3 mb-1 flex-wrap">
                        <label class="form-label mb-0">Text to extract a graph from</label>
                        <InputFile OnChange="LoadSourceFileAsync" style="font-size: 0.8em; max-width: 240px;" title="Load a file's text into the box — Word, Excel, CSV, or any text-based format" />
                        <div class="input-group input-group-sm" style="width: 300px;">
                            <input class="form-control" placeholder="…or a Wikipedia article title" @bind="wikipediaTitle" title="Fetch the article's plain text from the English Wikipedia" />
                            <button class="btn btn-outline-secondary" @onclick="FetchWikipediaAsync" disabled="@(string.IsNullOrWhiteSpace(wikipediaTitle) || fetchingWiki)">@(fetchingWiki ? "Fetching…" : "Fetch")</button>
                        </div>
                    </div>
                    <div class="form-text mt-0 mb-1" style="font-size: 0.75em;">
                        Files: <span class="fw-semibold">.docx</span>, <span class="fw-semibold">.xlsx</span>, <span class="fw-semibold">.csv</span>, <span class="fw-semibold">.txt / .md</span> — or any other text-based format, opened as text automatically. PDF isn't supported (no text extractor in the browser). Wikipedia fetches the article's plain text.
                    </div>
                    <textarea class="form-control mb-2" style="height: 10em; resize: vertical;" placeholder="Paste notes, an article, a document…" @bind="sourceText" @bind:event="oninput"></textarea>

                    <div class="d-flex gap-3 align-items-end flex-wrap mb-2">
                        <div style="flex: 1 1 320px;">
                            <label class="form-label mb-1">Optional instruction</label>
                            <input class="form-control" placeholder="e.g. focus on people and organizations" @bind="instruction" />
                        </div>

                        @if (Schema != null)
                        {
                            <div class="form-check mb-1" title="Ask the model to reuse the connected database's vertex/edge labels and property keys instead of inventing its own.">
                                <input class="form-check-input" type="checkbox" id="kgGroundSchema" @bind="groundInSchema" />
                                <label class="form-check-label" for="kgGroundSchema">Ground labels in the connected schema</label>
                            </div>
                        }
                    </div>

                    @* ── Merge / Replace (AC 9) — remembered across sessions ─── *@
                    <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
                        <div class="btn-group btn-group-sm" role="group" aria-label="Merge or replace">
                            <button type="button" class="btn @(mergeMode ? "btn-outline-danger" : "btn-danger")" @onclick="() => SetModeAsync(false)">Replace drawing</button>
                            <button type="button" class="btn @(mergeMode ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetModeAsync(true)">Merge into drawing</button>
                        </div>
                        <div class="form-text my-0">Replace wipes the current drawing (it asks first when changes are staged). Merge adds onto it, folding entities that are already there.</div>
                    </div>

                    @* ── Generate ────────────────────────────────────────────── *@
                    <br />

                    <div class="d-flex gap-2 align-items-center mb-2">
                        <button class="btn btn-primary" @onclick="GenerateAsync" disabled="@(selected == null || string.IsNullOrWhiteSpace(sourceText) || generating)">
                            @(generating ? "Generating…" : "Generate graph")
                        </button>
                        @if (generating)
                        {
                            <button class="btn btn-outline-secondary" @onclick="Cancel" title="Cancel generation">Cancel</button>
                        }
                        <div class="form-text flex-grow-1 my-0">Your text@(groundInSchema && Schema != null ? " and the connected schema" : "") are sent to the selected model provider. Nothing is drawn or written until you accept the preview.</div>
                    </div>

                    <br />

                    @if (error != null)
                    {
                        <div class="alert alert-danger py-2 small mb-2">@error</div>

                        @if (rawModelOutput != null)
                        {
                            <label class="form-label mb-1">Raw model output</label>
                            <pre class="border rounded p-2 mb-2" style="white-space: pre-wrap; max-height: 30vh; overflow: auto;">@rawModelOutput</pre>
                        }
                    }

                    @* ── Preview — true for the chosen mode (AC 8) ───────────── *@
                    @if (previewGremlin != null)
                    {
                        <div class="d-flex gap-3 align-items-baseline flex-wrap bg-body-tertiary border rounded px-3 py-2">
                            <span class="fw-semibold">@countsLine</span>
                            @if (!string.IsNullOrEmpty(labelBreakdown))
                            {
                                <span class="text-muted small">@labelBreakdown</span>
                            }
                        </div>

                        @if (previewWarnings.Count > 0)
                        {
                            <div class="alert alert-warning py-2 small mb-2 mt-2">
                                @foreach (var warning in previewWarnings)
                                {
                                    <div>@warning</div>
                                }
                            </div>
                        }

                        @if (previewGremlin.Length == 0)
                        {
                            <div class="text-muted small mt-1">Nothing new — everything in this generation is already on the canvas.</div>
                        }
                        else
                        {
                            <label class="form-label mb-1 mt-2">Generated queries</label>
                            <pre class="border rounded p-2 mb-1" style="white-space: pre-wrap; flex: 1 1 auto; min-height: 6em; max-height: 35vh; overflow: auto;">@previewGremlin</pre>
                        }
                    }

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success" @onclick="UseGraphAsync" disabled="@(string.IsNullOrEmpty(previewGremlin))">Use this graph →</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    ///<summary>The connected schema's vocabulary, or null when grounding isn't available (nothing
    ///connected, or the schema is unknown). Null hides the grounding toggle entirely.</summary>
    [Parameter] public SchemaVocabulary Schema { get; set; }

    ///<summary>The canvas as its render JSON (EffectiveData()) — what Merge folds against. Undefined
    ///reads as an empty canvas.</summary>
    [Parameter] public JsonElement CurrentGraph { get; set; }

    ///<summary>Raised on accept with the script to stage and the chosen mode. Replace routes through the
    ///guarded import path; Merge appends the precomputed delta. The modal never commits (AC 10).</summary>
    [Parameter] public EventCallback<(string Gremlin, bool Merge)> OnUseGraph { get; set; }

    //The Merge/Replace toggle's persisted last value (AC 9): absent ⇒ false ⇒ Replace, so first use
    //defaults to Replace with no special-casing. Owned here — the toggle has exactly one consumer.
    private const string MergeModeKey = "graphdbviewer:kgMergeMode";

    //The connection the picker currently has selected; null when no models exist yet.
    private LlmConnection selected;

    //Inputs.
    private string sourceText;
    private string instruction;
    private bool groundInSchema;
    private bool mergeMode;
    private bool modeLoaded;

    //Generation state.
    private bool generating;
    private CancellationTokenSource cts;
    private string error;
    private string rawModelOutput;

    //The parsed generation (in-run folded — mode-independent), and the mode-true preview built from it.
    private GraphImport.Graph parsedGraph;
    private List<string> parseWarnings = new();
    private string previewGremlin;
    private string countsLine;
    private string labelBreakdown;
    private List<string> previewWarnings = new();

    //Tracks where the mouse was pressed so a selection drag from inside the dialog to the backdrop
    //doesn't close the modal — only a press that begins on the backdrop does.
    private bool backdropMouseDown;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !modeLoaded)
        {
            modeLoaded = true;
            mergeMode = await Storage.GetAsync<bool>(MergeModeKey);
        }
    }

    private async Task CloseIfBackdropAsync()
    {
        if (backdropMouseDown)
            await OnClose.InvokeAsync();
    }

    //Upload cap: this is a paste-sized feature, and a graph extracted from more text than this would
    //blow the node/edge caps anyway.
    private const long MaxSourceFileBytes = 1024 * 1024;

    private async Task LoadSourceFileAsync(InputFileChangeEventArgs e)
    {
        error = null;

        var file = e.File;

        if (file == null)
            return;

        if (file.Size > MaxSourceFileBytes)
        {
            error = $"\"{file.Name}\" is {file.Size / 1024} KB; the cap is {MaxSourceFileBytes / 1024} KB. Paste an excerpt instead.";
            return;
        }

        //Buffer first: the extractor needs a seekable stream (ZIP-based formats), and InputFile's
        //stream is async-only.
        using var buffer = new System.IO.MemoryStream();
        await file.OpenReadStream(MaxSourceFileBytes).CopyToAsync(buffer);
        buffer.Position = 0;

        var (text, extractError) = SourceTextExtractor.Extract(file.Name, buffer);

        if (extractError != null)
            error = extractError;
        else
            sourceText = text;
    }

    //Wikipedia fetch state.
    private string wikipediaTitle;
    private bool fetchingWiki;

    private async Task FetchWikipediaAsync()
    {
        if (string.IsNullOrWhiteSpace(wikipediaTitle) || fetchingWiki)
            return;

        error = null;
        fetchingWiki = true;

        try
        {
            var (text, fetchError) = await WikipediaSource.FetchExtractAsync(Http, wikipediaTitle, CancellationToken.None);

            if (fetchError != null)
                error = fetchError;
            else
                sourceText = text;
        }
        finally
        {
            fetchingWiki = false;
        }
    }

    private async Task SetModeAsync(bool merge)
    {
        if (mergeMode == merge)
            return;

        mergeMode = merge;

        //The preview must stay true for the chosen mode (AC 8), so switching recomputes it.
        RecomputePreview();

        await Storage.SetAsync(MergeModeKey, merge);
    }

    private async Task GenerateAsync()
    {
        if (selected == null || string.IsNullOrWhiteSpace(sourceText))
            return;

        error = null;
        rawModelOutput = null;
        parsedGraph = null;
        parseWarnings = new List<string>();
        previewGremlin = null;
        generating = true;
        cts?.Dispose();
        cts = new CancellationTokenSource();

        try
        {
            var provider = LlmProviderFactory.Create(Http, selected);

            SchemaVocabulary schemaArg = null;

            if (groundInSchema)
                schemaArg = Schema;

            var system = KgPrompt.BuildSystemPrompt(schemaArg);
            var user = sourceText.Trim();

            if (!string.IsNullOrWhiteSpace(instruction))
                user = $"{user}\n\nAdditional instruction: {instruction.Trim()}";

            //Single-shot on purpose — no tool loop (design § Why generation gets no tools) — and the
            //output cap is the connection's own MaxTokens, inherited through the factory (AC 7).
            var result = await provider.CompleteAsync(system, user, cts.Token);

            if (result.IsError)
            {
                error = result.Error;
                return;
            }

            var parsed = KgGraphParser.Parse(result.Text);

            if (parsed.IsError)
            {
                //Fail loudly with the raw output shown (AC 6). Truncation presents as invalid JSON, so
                //name the likely cause (AC 7).
                error = parsed.Error;

                if (parsed.Error.Contains("not valid JSON"))
                    error += " If the output was cut off mid-graph, raise the connection's Max tokens.";

                rawModelOutput = result.Text;
                return;
            }

            parsedGraph = parsed.Graph;
            parseWarnings = parsed.Warnings;
            RecomputePreview();
        }
        catch (OperationCanceledException)
        {
            error = "Generation canceled.";
        }
        catch (Exception ex)
        {
            //A CORS preflight rejection surfaces as a bare fetch failure — the likeliest real error for
            //a custom/local endpoint. Name the cause, with the connection card's wording.
            error = ex.Message;

            if (ex is HttpRequestException || error.Contains("Failed to fetch"))
                error += " (If this is a CORS error, the endpoint must allow this origin.)";
        }
        finally
        {
            generating = false;
            cts?.Dispose();
            cts = null;
        }
    }

    //Builds the preview for the chosen mode from the parsed generation: Replace previews the whole
    //graph; Merge folds against the canvas first, so the counts describe the post-merge result and a
    //folding entity is not counted as new (AC 8). The fold runs here, in the modal, because whatever
    //decides what folds must run before the user accepts.
    private void RecomputePreview()
    {
        previewGremlin = null;
        countsLine = null;
        labelBreakdown = null;
        previewWarnings = new List<string>(parseWarnings);

        if (parsedGraph == null)
            return;

        if (mergeMode)
        {
            var canvas = KgGraphParser.FromRenderJson(CurrentGraph);
            var merge = KgGraphParser.FoldAgainstCanvas(parsedGraph, canvas);

            previewGremlin = merge.DeltaGremlin;
            previewWarnings.AddRange(merge.Warnings);
            countsLine = $"{merge.NewNodes} new node(s) · {merge.NewEdges} new edge(s) · {merge.FoldedNodes} merged into existing · {merge.PropertyUpdates} property update(s)";
            labelBreakdown = BreakdownOf(merge.AddedNodes);
        }
        else
        {
            previewGremlin = GraphImport.ToGremlin(parsedGraph);
            countsLine = $"{parsedGraph.Nodes.Count} node(s) · {parsedGraph.Edges.Count} edge(s)";
            labelBreakdown = BreakdownOf(parsedGraph.Nodes);
        }
    }

    private static string BreakdownOf(List<GraphImport.Node> nodes)
    {
        if (nodes.Count == 0)
            return null;

        return string.Join(" · ", nodes.GroupBy(n => n.Label)
            .OrderByDescending(g => g.Count())
            .Select(g => $"{g.Key} ×{g.Count()}"));
    }

    private void Cancel()
    {
        cts?.Cancel();
    }

    private async Task UseGraphAsync()
    {
        if (string.IsNullOrEmpty(previewGremlin))
            return;

        await OnUseGraph.InvokeAsync((previewGremlin, mergeMode));
        await OnClose.InvokeAsync();
    }
}
