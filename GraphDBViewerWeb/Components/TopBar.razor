<div class="card d-flex flex-row flex-wrap align-items-center gap-2 mb-2 p-2">

    <img src="favicon.svg" alt="Logo" class="ms-1" style="width: 2.2rem; height: 1.8rem; flex-shrink: 0;" />

    <div class="d-flex flex-column me-5" style="line-height: 1;">
        <h1 class="mb-0" style="font-size: 1.25rem; line-height: 1;">Graph DB Viewer</h1>
        <span style="font-size: 0.62rem; color: #d4af37; align-self: flex-end;">Web edition</span>
    </div>

    <button class="btn @ConnectionButtonClass btn-sm @(Pulse ? "gdbv-pulse" : "")" @onclick="OnToggleConnectionCard" title="@(Offline && !IsConnected ? "Offline drawing mode — open the connection card to exit it or connect" : null)">
        @ConnectionButtonText
        <span class="ms-1">@(ConnectionCardExpanded ? "▲" : "▼")</span>
    </button>

    <button class="btn btn-outline-secondary btn-sm ms-2 text-body-emphasis" @onclick="OnToggleImportExport">
        Import / Export
        <span class="ms-1">@(ImportExportExpanded ? "▲" : "▼")</span>
    </button>

    @* Feature showcase — opens the full-screen showcase overlay. Starts the right-aligned button group. *@
    <button type="button" class="btn btn-outline-secondary btn-sm text-body-emphasis ms-auto" @onclick="OnShowShowcase" title="Open the feature showcase">
        Feature showcase ✨
    </button>

    @* Full-width toggle: drops the side margins so the layout fills the viewport. A little spacing from the showcase button. *@
    <button type="button" class="btn btn-outline-secondary btn-sm text-body-emphasis ms-2 @(FullScreen ? "active" : null)" @onclick="OnToggleFullScreen" aria-pressed="@(FullScreen ? "true" : "false")" title="@(FullScreen ? "Exit full-width — restore the side margins" : "Full-width — remove the side margins")">
        @if (FullScreen)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="vertical-align: -2px;">
                <path d="M5.5 0a.5.5 0 0 1 .5.5v4A1.5 1.5 0 0 1 4.5 6h-4a.5.5 0 0 1 0-1h4a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 .5-.5m5 0a.5.5 0 0 1 .5.5v4a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 10 4.5v-4a.5.5 0 0 1 .5-.5M0 10.5a.5.5 0 0 1 .5-.5h4A1.5 1.5 0 0 1 6 11.5v4a.5.5 0 0 1-1 0v-4a.5.5 0 0 0-.5-.5h-4a.5.5 0 0 1-.5-.5m10 1a1.5 1.5 0 0 1 1.5-1.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 0-.5.5v4a.5.5 0 0 1-1 0z"/>
            </svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="vertical-align: -2px;">
                <path d="M1.5 1a.5.5 0 0 0-.5.5v4a.5.5 0 0 1-1 0v-4A1.5 1.5 0 0 1 1.5 0h4a.5.5 0 0 1 0 1zM10 .5a.5.5 0 0 1 .5-.5h4A1.5 1.5 0 0 1 16 1.5v4a.5.5 0 0 1-1 0v-4a.5.5 0 0 0-.5-.5h-4a.5.5 0 0 1-.5-.5M.5 10a.5.5 0 0 1 .5.5v4a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 0 14.5v-4a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v4a1.5 1.5 0 0 1-1.5 1.5h-4a.5.5 0 0 1 0-1h4a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 .5-.5"/>
            </svg>
        }
    </button>

    @* Settings dropdown (right side) — holds the theme switch, About, and future options. *@
    <div class="position-relative ms-2">
        <button class="btn btn-outline-secondary btn-sm text-body-emphasis" @onclick="() => showSettings = !showSettings" title="Settings">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="vertical-align: -2px;">
                <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115z"/>
            </svg>
            Settings <span class="ms-1">@(showSettings ? "▲" : "▼")</span>
        </button>

        @if (showSettings)
        {
            @* Transparent full-viewport backdrop: a click anywhere outside the menu closes it. *@
            <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: 1070;" @onclick="() => showSettings = false"></div>

            <div class="card position-absolute end-0 mt-1 py-1 shadow" style="z-index: 1080; min-width: 225px;">
                <label class="form-switch d-flex align-items-center justify-content-between px-3 py-2 mb-0 border-bottom" style="cursor: pointer;">
                    <span>Dark mode</span>
                    <input class="form-check-input m-0" type="checkbox" role="switch" id="darkModeSwitch" checked="@DarkMode" @onchange="ToggleDarkFromMenu" style="cursor: pointer;" />
                </label>

                @* Nested "Query settings" section: the query limit (a copy of the sidebar control) and the expand limit. *@
                <button class="dropdown-item d-flex align-items-center justify-content-between px-3 py-2 border-bottom" @onclick="() => showQuerySettings = !showQuerySettings">
                    <span>Query settings</span>
                    <span class="ms-2">@(showQuerySettings ? "▲" : "▼")</span>
                </button>

                @if (showQuerySettings)
                {
                    <div class="bg-body-tertiary border-bottom">
                        <label class="d-flex align-items-center justify-content-between ps-4 pe-3 py-2 mb-0" title="Max vertices a query or Load DB pulls from the database (same as the query-limit box by the editor)">
                            <span>Query limit</span>
                            <input class="form-control form-control-sm m-0" type="number" min="1" style="width: 5rem;" value="@QueryLimit" @onchange="OnQueryLimitInput" />
                        </label>
                        <label class="d-flex align-items-center justify-content-between ps-4 pe-3 py-2 mb-0" title="The most neighbors pulled in when you double-click a node to expand it">
                            <span>Expand limit</span>
                            <input class="form-control form-control-sm m-0" type="number" min="1" max="5000" style="width: 5rem;" value="@ExpansionLimit" @onchange="OnExpansionLimitInput" />
                        </label>
                    </div>
                }

                <button class="dropdown-item px-3 py-2" @onclick="ShowAboutFromMenu">About</button>
            </div>
        }
    </div>

</div>

@code {
    [Parameter] public bool IsConnected { get; set; }
    [Parameter] public bool Offline { get; set; }
    [Parameter] public bool Pulse { get; set; }
    [Parameter] public string Hostname { get; set; }
    [Parameter] public int Port { get; set; }
    [Parameter] public bool ConnectionCardExpanded { get; set; }
    [Parameter] public bool ImportExportExpanded { get; set; }
    [Parameter] public bool DarkMode { get; set; }
    [Parameter] public bool FullScreen { get; set; }
    [Parameter] public int ExpansionLimit { get; set; }
    [Parameter] public EventCallback<int> OnExpansionLimitChanged { get; set; }
    [Parameter] public int QueryLimit { get; set; }
    [Parameter] public EventCallback<int> OnQueryLimitChanged { get; set; }
    [Parameter] public EventCallback OnToggleConnectionCard { get; set; }
    [Parameter] public EventCallback OnToggleImportExport { get; set; }
    [Parameter] public EventCallback OnToggleDarkMode { get; set; }
    [Parameter] public EventCallback OnToggleFullScreen { get; set; }
    [Parameter] public EventCallback OnShowAbout { get; set; }
    [Parameter] public EventCallback OnShowShowcase { get; set; }

    //The connection button doubles as the app's mode indicator: green when connected, blue while drawing
    //offline, gray otherwise. Offline mode used to be invisible here — the bar kept saying "Disconnected"
    //while the card holding the "Exit offline mode" toggle had closed, leaving no visible way back out.
    private string ConnectionButtonClass
    {
        get
        {
            if (IsConnected)
                return "btn-outline-success";

            if (Offline)
                return "btn-outline-primary";

            return "btn-outline-secondary";
        }
    }

    private string ConnectionButtonText
    {
        get
        {
            if (IsConnected)
                return $"Connected — {HostLabel}";

            if (Offline)
                return "Offline mode";

            return $"Disconnected — {HostLabel}";
        }
    }

    private string HostLabel
    {
        get
        {
            if (string.IsNullOrEmpty(Hostname))
                return $"No host:{Port}";

            return $"{Hostname}:{Port}";
        }
    }

    //Whether the Settings dropdown is open. The theme switch keeps it open (a live toggle);
    //About closes it since it opens a modal.
    private bool showSettings;

    //Whether the nested "Query settings" section (query limit + expand limit) is expanded. Open by default.
    private bool showQuerySettings = true;

    private async Task ToggleDarkFromMenu()
    {
        await OnToggleDarkMode.InvokeAsync();
    }

    private async Task ShowAboutFromMenu()
    {
        showSettings = false;
        await OnShowAbout.InvokeAsync();
    }

    private async Task OnExpansionLimitInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
            await OnExpansionLimitChanged.InvokeAsync(value);
    }

    private async Task OnQueryLimitInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
            await OnQueryLimitChanged.InvokeAsync(value);
    }
}
