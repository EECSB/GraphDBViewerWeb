@using GraphDBViewerWeb.Code
@inject LlmConnectionStore Store

@* The saved AI-model picker + its add/edit form, shared by every AI feature ("Ask AI" today, the
   knowledge-graph generator next) so a model configured once is offered everywhere. Owns the CRUD via
   LlmConnectionStore; the parent only learns which connection is picked, through SelectedChanged. *@

<label class="form-label mb-1">AI model</label>
<div class="input-group mb-2" style="max-width: 380px;">
    <select class="form-select" value="@selectedKey" @onchange="OnSelectionChangedAsync">
        @if (connections.Count == 0)
        {
            <option value="">-- No models yet — add one --</option>
        }
        @foreach (var kv in connections)
        {
            <option value="@kv.Key">@kv.Key (@kv.Value.ProviderType)</option>
        }
    </select>
    <button class="btn btn-success" style="border-top-color: var(--bs-border-color); border-bottom-color: var(--bs-border-color); border-left: 0; border-right: 0;" @onclick="StartAdd" title="Add an AI model">+</button>
    <button class="btn btn-danger" style="border-top-color: var(--bs-border-color); border-bottom-color: var(--bs-border-color); border-left: 0; border-right: 0;" @onclick="DeleteAsync" disabled="@(Selected == null)" title="Delete selected model">&minus;</button>
    <button class="btn btn-primary" style="border-top-color: var(--bs-border-color); border-bottom-color: var(--bs-border-color); border-right-color: var(--bs-border-color); border-left: 0;" @onclick="StartEdit" disabled="@(Selected == null)" title="Edit selected model">Edit</button>
</div>

@if (showForm)
{
    <div class="card border-secondary p-3 mb-3">
        <h6 class="mb-3">@(isEditing ? "Edit model" : "New model")</h6>

        <div class="mb-2">
            <label class="form-label">Name <span class="text-danger">*</span></label>
            <input class="form-control @(formError != null ? "is-invalid" : "")" placeholder="e.g. Claude Opus" @bind="formName" />
            @if (formError != null)
            {
                <div class="invalid-feedback">@formError</div>
            }
        </div>

        <div class="mb-2">
            <label class="form-label d-block">Provider</label>
            <div class="btn-group btn-group-sm" role="group" aria-label="Provider">
                <button type="button" class="btn @(form.ProviderType == "Anthropic" ? "btn-primary" : "btn-outline-primary")" @onclick='() => form.ProviderType = "Anthropic"'>Anthropic</button>
                <button type="button" class="btn @(form.ProviderType == "OpenAI" ? "btn-primary" : "btn-outline-primary")" @onclick='() => form.ProviderType = "OpenAI"'>OpenAI</button>
                <button type="button" class="btn @(form.ProviderType == "Gemini" ? "btn-primary" : "btn-outline-primary")" @onclick='() => form.ProviderType = "Gemini"'>Gemini</button>
                <button type="button" class="btn @(form.ProviderType == "Custom" ? "btn-primary" : "btn-outline-primary")" @onclick='() => form.ProviderType = "Custom"'>Other</button>
            </div>
            <div class="form-text" style="font-size: 0.75em;">Gemini = Google's free-tier models — get a key from Google AI Studio (aistudio.google.com). Other = any OpenAI-compatible server (Ollama, LM Studio, vLLM, Azure, self-hosted).</div>
        </div>

        @if (form.ProviderType != "Anthropic")
        {
            <div class="mb-2">
                <label class="form-label">Base URL @if (BaseUrlOptional){<text>(optional)</text>}else{<span class="text-danger">*</span>}</label>
                <input class="form-control" placeholder="@BaseUrlPlaceholder" @bind="form.BaseUrl" />
            </div>
        }

        <div class="mb-2 row">
            <div class="col">
                <label class="form-label">Model @if (ModelRequired){<span class="text-danger">*</span>}</label>
                <input class="form-control" placeholder="@ModelPlaceholder" @bind="form.Model" />
            </div>
            <div class="col">
                <label class="form-label">API key @if (ApiKeyRequired){<span class="text-danger">*</span>}</label>
                <input class="form-control" type="password" @bind="form.ApiKey" />
            </div>
            @* Only Anthropic sends a cap — the OpenAI-compatible adapter leaves it to the
               server, so the box would do nothing for the other providers. *@
            @if (SendsMaxTokens)
            {
                <div class="col-3">
                    <label class="form-label">Max tokens</label>
                    <input class="form-control" type="number" min="1" @bind="form.MaxTokens" title="Ceiling on the answer's length. It's a limit, not an allowance — you're billed for what the model actually writes — so raise it if a long answer stops mid-sentence." />
                </div>
            }
        </div>

        <div class="d-flex gap-2 mt-1">
            <button class="btn btn-primary" @onclick="SaveFormAsync">@(isEditing ? "Save" : "Add")</button>
            <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    </div>
}

@code {
    ///<summary>Raised whenever the picked connection changes — on load, selection, save and delete.
    ///Null means no models exist. The parent generates with what this hands it.</summary>
    [Parameter] public EventCallback<LlmConnection> SelectedChanged { get; set; }

    private Dictionary<string, LlmConnection> connections = new();
    private string selectedKey;

    //Add / edit form state.
    private bool showForm;
    private bool isEditing;
    private string formName;
    private string originalName;
    private LlmConnection form = new();
    private string formError;

    private LlmConnection Selected
    {
        get
        {
            if (!string.IsNullOrEmpty(selectedKey) && connections.TryGetValue(selectedKey, out var c))
                return c;

            return null;
        }
    }

    private string ModelPlaceholder
    {
        get
        {
            //Anthropic is the one provider whose model is optional (see ModelRequired), so its placeholder
            //has to name the model a blank field actually runs — and it reads that from the provider, so the
            //two can't drift apart again. The others are required fields, where the placeholder is only an
            //example of what to type.
            if (form.ProviderType == "Anthropic")
                return $"{AnthropicProvider.DefaultModel} (default)";

            if (form.ProviderType == "OpenAI")
                return "gpt-4o-mini";

            if (form.ProviderType == "Gemini")
                return "gemini-2.5-flash";

            return "model name";
        }
    }

    //Gemini and OpenAI have a sensible default endpoint, so the Base URL is optional; a custom server needs one.
    private bool BaseUrlOptional => form.ProviderType == "OpenAI" || form.ProviderType == "Gemini";

    //An API key is required for the hosted providers; a local OpenAI-compatible server ("Other") may not need one.
    private bool ApiKeyRequired => form.ProviderType != "Custom";

    //Every provider needs a model id except Anthropic, which falls back to a built-in default.
    private bool ModelRequired => form.ProviderType != "Anthropic";

    //Only the Anthropic adapter sends an output cap; the OpenAI-compatible one lets the server decide.
    private bool SendsMaxTokens => form.ProviderType == "Anthropic";

    private string BaseUrlPlaceholder
    {
        get
        {
            if (form.ProviderType == "Gemini")
                return OpenAiProvider.GeminiBaseUrl;

            if (form.ProviderType == "Custom")
                return "http://localhost:11434/v1";

            return OpenAiProvider.DefaultBaseUrl;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        connections = await Store.LoadAsync();
        selectedKey = connections.Keys.FirstOrDefault();

        await NotifySelectedAsync();
    }

    private async Task NotifySelectedAsync()
    {
        await SelectedChanged.InvokeAsync(Selected);
    }

    private async Task OnSelectionChangedAsync(ChangeEventArgs e)
    {
        selectedKey = e.Value?.ToString();

        await NotifySelectedAsync();
    }

    private void StartAdd()
    {
        isEditing = false;
        form = new LlmConnection();
        formName = string.Empty;
        originalName = null;
        formError = null;
        showForm = true;
    }

    private void StartEdit()
    {
        if (Selected == null)
            return;

        isEditing = true;
        form = new LlmConnection(Selected);
        formName = Selected.Name;
        originalName = Selected.Name;
        formError = null;
        showForm = true;
    }

    private async Task SaveFormAsync()
    {
        var name = formName?.Trim();

        if (string.IsNullOrEmpty(name))
        {
            formError = "Name is required.";
            return;
        }

        if ((!isEditing || name != originalName) && connections.ContainsKey(name))
        {
            formError = "A model with that name already exists.";
            return;
        }

        if (isEditing && originalName != null && name != originalName)
            connections.Remove(originalName);

        form.Name = name;
        connections[name] = form;
        selectedKey = name;
        showForm = false;
        formError = null;

        await Store.SaveAsync(connections);
        await NotifySelectedAsync();
    }

    private void CancelForm()
    {
        showForm = false;
        formError = null;
    }

    private async Task DeleteAsync()
    {
        if (Selected == null)
            return;

        connections.Remove(selectedKey);
        selectedKey = connections.Keys.FirstOrDefault();

        await Store.SaveAsync(connections);
        await NotifySelectedAsync();
    }
}
