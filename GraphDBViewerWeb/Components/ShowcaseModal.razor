@* A full-screen overlay that shows the app's showcase page (the landing page, bundled into wwwroot at
   /showcase) in an iframe. Opened from the Settings menu and from the About dialog. *@

@inject NavigationManager Nav

@if (Visible)
{
    <div style="position: fixed; inset: 0; z-index: 2000; display: flex; flex-direction: column; background: var(--bs-body-bg);">
        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom" style="flex-shrink: 0;">
            <span class="fw-bold d-inline-flex align-items-center gap-2">✨ Graph DB Viewer — feature showcase</span>
            <button type="button" class="btn-close" @onclick="OnClose" title="Close the showcase"></button>
        </div>
        @* Resolve against the app base URI (always ends with '/') rather than a bare relative path: on a
           sub-path deployment the base href can lack a trailing slash, which would drop the last segment and
           point the iframe at the wrong folder. *@
        <iframe src="@($"{Nav.BaseUri}showcase/index.html")" title="Graph DB Viewer feature showcase" style="flex: 1 1 auto; width: 100%; height: 100%; border: 0;"></iframe>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
